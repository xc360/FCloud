{
  "name": "file-client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4212 --open --proxy-config proxy.conf.json",
    "build": "ng build --prod --aot --base-href /",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "clean": "npm run clean_ccxc && npm run clean_lock",
    "clean_ccxc": "if exist .\\node_modules\\@ccxc del /s /q .\\node_modules\\@ccxc && if exist .\\node_modules\\@ccxc rd /s /q .\\node_modules\\@ccxc",
    "clean_lock": "if exist .\\package-lock.json del /s /q .\\package-lock.json"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~9.1.13",
    "@angular/common": "~9.1.13",
    "@angular/compiler": "~9.1.13",
    "@angular/core": "~9.1.13",
    "@angular/forms": "~9.1.13",
    "@angular/platform-browser": "~9.1.13",
    "@angular/platform-browser-dynamic": "~9.1.13",
    "@angular/router": "~9.1.13",
    "ng-zorro-antd": "^8.5.2",
    "rxjs": "~6.6.3",
    "spark-md5": "^3.0.1",
    "tslib": "^1.10.0",
    "viewerjs": "^1.9.1",
    "zone.js": "~0.10.2",
    "@ccxc/common": "1.0.3",
    "@ccxc/tool": "1.0.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.901.13",
    "@angular/cli": "~9.1.13",
    "@angular/compiler-cli": "~9.1.13",
    "@angular/language-service": "~9.1.13",
    "@types/node": "^12.11.1",
    "@types/jasmine": "~3.3.8",
    "@types/jasminewd2": "~2.0.3",
    "node-sass": "^4.13.1",
    "codelyzer": "^5.0.0",
    "jasmine-core": "~3.4.0",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "~4.1.0",
    "karma-chrome-launcher": "~2.2.0",
    "karma-coverage-istanbul-reporter": "~2.0.1",
    "karma-jasmine": "~2.0.1",
    "karma-jasmine-html-reporter": "^1.4.0",
    "protractor": "~5.4.0",
    "ts-node": "~7.0.0",
    "tslint": "~5.15.0",
    "typescript": "~3.8.3"
  }
}
